# ── Frontend API target ───────────────────────────────────────────────────────
# Set to the deployed backend URL in production; leave blank for localhost
VITE_API_URL=http://localhost:8000

# ── HyperFrames Player (frontend) ────────────────────────────────────────────
# Set to "true" to activate the <hyperframes-player> branch in the modal.
# Only flip after ENABLE_COMPOSITION_ENGINE=true is verified on the backend.
VITE_USE_HYPERFRAMES_PLAYER=false


# ── NVIDIA NIM (PulseBoard backend) ──────────────────────────────────────────
# Get a free key at https://build.nvidia.com/
NVIDIA_API_KEY=nvapi-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1
NVIDIA_MODEL=meta/llama-3.3-70b-instruct

# ── Backblaze B2 (PulseBoard backend) ────────────────────────────────────────
# Create an Application Key in the B2 console (read+write on your bucket)
B2_KEY_ID=your_b2_application_key_id
B2_APP_KEY=your_b2_application_key_secret
B2_BUCKET_NAME=pulseboard-explainers
# Find your endpoint in: B2 Console → Buckets → Endpoint
B2_ENDPOINT_URL=https://s3.us-west-004.backblazeb2.com

# ── Research Grounding (Tavily) ───────────────────────────────────────────────
# Get a free key at https://app.tavily.com/
TAVILY_API_KEY=tvly-...

# ── Pipeline tuning ───────────────────────────────────────────────────────────
MAX_RETRIES=3
TARGET_STEPS=4
ENVIRONMENT=development

# ── Composition Engine (HyperFrames) ─────────────────────────────────────────
ENABLE_COMPOSITION_ENGINE=false

# ── NVIDIA NIM ────────────────────────────────────────────────────────────────
# Get a free key at https://build.nvidia.com/
NVIDIA_API_KEY=nvapi-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# NIM OpenAI-compatible endpoint (default for build.nvidia.com hosted models)
NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1

# Model to use for explainer generation (llama-3.3-70b-instruct is free-tier capable)
NVIDIA_MODEL=meta/llama-3.3-70b-instruct

# ── Backblaze B2 ──────────────────────────────────────────────────────────────
# Create an Application Key in the B2 console with read+write on your bucket
B2_KEY_ID=your_b2_application_key_id
B2_APP_KEY=your_b2_application_key_secret

# The bucket name (must already exist in your B2 account)
B2_BUCKET_NAME=pulseboard-explainers

# S3-compatible endpoint — replace the region suffix (e.g. us-west-004) to match yours
# Find yours in the B2 console under Buckets → Endpoint
B2_ENDPOINT_URL=https://s3.us-west-004.backblazeb2.com

# ── Generation Pipeline ───────────────────────────────────────────────────────
# Max LLM retries when JSON validation fails
MAX_RETRIES=3

# Number of slides to request per explainer
TARGET_STEPS=4

# ── Server ────────────────────────────────────────────────────────────────────
# Set to "development" to enable CORS wildcard and detailed error responses
ENVIRONMENT=development
